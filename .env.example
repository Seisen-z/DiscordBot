# Copy to .env and fill real values. Never commit secrets.

# Discord bot token from Discord Developer Portal -> Bot.
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Configuration is now guild-agnostic via dashboard.

# Optional media tool path
# FFMPEG_PATH=C:\path\to\ffmpeg.exe

# Webhook Details
WEBHOOK_URL=YOUR_WEBHOOK_URL
WEBHOOK_HMAC_SECRET=YOUR_WEBHOOK_HMAC_SECRET
WEBHOOK_HMAC_HEADER=YOUR_WEBHOOK_HMAC_HEADER
GIVEAWAY_KEY_WEBHOOK_LIFETIME=YOUR_LIFETIME_WEBHOOK_URL
GIVEAWAY_KEY_WEBHOOK_MONTHLY=YOUR_MONTHLY_WEBHOOK_URL
GIVEAWAY_KEY_WEBHOOK_WEEKLY=YOUR_WEEKLY_WEBHOOK_URL

# Activity rewards (random key drops for active chatters)
ACTIVITY_REWARDS_ENABLED=1
ACTIVITY_REWARDS_WEBHOOK_WEEKLY=YOUR_ACTIVITY_WEEKLY_WEBHOOK_URL
ACTIVITY_REWARDS_WEBHOOK_5D=YOUR_ACTIVITY_5D_WEBHOOK_URL
ACTIVITY_REWARDS_WEBHOOK_HMAC_SECRET=YOUR_ACTIVITY_WEBHOOK_HMAC_SECRET
ACTIVITY_REWARDS_WEBHOOK_HMAC_HEADER=coms
ACTIVITY_REWARDS_WEBHOOK_TIMEOUT_SECONDS=12
ACTIVITY_REWARDS_MIN_MESSAGES_LOW=200
ACTIVITY_REWARDS_MIN_MESSAGES_HIGH=300
ACTIVITY_REWARDS_DRAW_INTERVAL_MINUTES=360
ACTIVITY_REWARDS_COOLDOWN_DAYS=7
ACTIVITY_REWARDS_DAILY_WINNER_CAP=3
ACTIVITY_REWARDS_WEEKLY_WINNER_CAP=12
ACTIVITY_REWARDS_KEY_POOL=activity_pool
ACTIVITY_REWARDS_EVENT_WEBHOOK_ENABLED=0
ACTIVITY_REWARDS_EVENT_WEBHOOK_URL=
ACTIVITY_REWARDS_EVENT_WEBHOOK_RETRY_COUNT=2

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Discord dashboard rate limits: longer TTLs = fewer API calls (seconds). Tune if you still see 429s.
# DISCORD_GUILD_RESOURCE_CACHE_TTL=300
# DISCORD_MANAGEABLE_GUILDS_CACHE_TTL=300
# DISCORD_ME_SESSION_TTL_SEC=600
# DISCORD_ACTOR_CACHE_TTL=300

# Public dashboard API port. On managed hosts this usually matches SERVER_PORT.
API_PORT=9977

# Internal bot IPC port used by api.py -> bot trigger bridge.
# Keep this separate from API_PORT.
IPC_PORT=9977

# Comma-separated browser origins allowed for CORS (dashboard). If unset, defaults include localhost:3000 and seisenbot.vercel.app.
# CORS_ORIGINS=http://localhost:3000,https://your-dashboard.example

# Set to 1 only for local debugging — exposes minimal /api/debug (never token material).
# ENABLE_DEBUG_API=0

# Local JSON database
# Shared state lives in ./database/*.json; keep that folder writable by the bot/API process.
